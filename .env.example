# Backend environment example for production or shared setup

API_ENV=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=5000
TRUST_PROXY_HEADERS=true

# Use a long random value in production
SECRET_KEY=replace-with-a-long-random-secret
TOKEN_EXPIRY_HOURS=24

# Comma-separated list or JSON array of allowed frontend origins
CORS_ORIGINS=https://your-frontend-domain.com

# Database and logs
DB_PATH=data/hoax.db
LOG_DIR=logs
ENABLE_LOGGING=true

# Super admin bootstrap
SUPER_ADMIN_USERNAME=super_admin
SUPER_ADMIN_EMAIL=super_admin@your-domain.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_TOKEN=replace-with-bootstrap-token

# Optional SMTP settings for password-reset notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
